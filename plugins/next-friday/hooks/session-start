#!/usr/bin/env bash
set -euo pipefail

context='This session may have the next-friday issue-driven workflow plugin available. It is optional and advisory: the actual task, explicit user instructions, CLAUDE.md, and saved feedback always take precedence over it.\n\nAssume the GitHub tracker is SHARED by parallel agents and people. Do not start the workflow on your own, and create or change no GitHub issue, branch, or PR without an explicit per-artifact go-ahead naming that artifact. Never infer an issue number, and never touch an issue, branch, or PR this session did not itself create.\n\nWhen the user explicitly asks to design or plan work, the `blueprint` skill turns an approved design into a plan. When the user names a specific issue to ship, `implement` branches, passes the gates, and opens a PR. When asked to handle AI code-review bot comments on a PR the session owns, `rebut` triages them. No outward GitHub action without explicit user direction.'

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
